# HealthOps Studio — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=healthops
POSTGRES_PASSWORD=healthops_dev_2024
POSTGRES_DB=healthops
DATABASE_URL=postgresql://healthops:healthops_dev_2024@localhost:5432/healthops

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT (RS256) ───────────────────────────────────────────
# Generate a key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the contents here (replace newlines with \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# ── Security ──────────────────────────────────────────────
# Used as an extra layer mixed into password hashing (Argon2id)
PASSWORD_PEPPER=change-me-to-something-random-in-production

# ── Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── App ───────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
